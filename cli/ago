#!/usr/bin/env bash
#
# ago — jail-by-default front-end for the real `ago` binary.
#
# Install this on PATH *ahead* of the compiled binary (e.g. ~/.local/bin/ago) and
# keep the real binary at AGO_REAL_BIN (default ~/.local/libexec/ago). When a
# command uses --client-tools (the only case where tools execute on YOUR machine)
# and jail is enabled, this wrapper runs the SAME binary inside a container that
# mounts ONLY the current directory as /work — so shell_exec physically cannot
# touch any file outside the project root, even with an absolute path like
# `rm /home/you/...`. Everything else runs the binary natively.
#
# jail resolution (first match wins):
#   1. $AGO_JAIL            (true/false)        — per-invocation override
#   2. .ago.yaml `jail:`    (walked up from cwd)
#   3. ~/.config/ago/launcher.toml `jail =`     — global default
#   4. true                                     — jail-by-default
set -euo pipefail

REAL_BIN="${AGO_REAL_BIN:-$HOME/.local/libexec/ago}"
LAUNCHER_CFG="${XDG_CONFIG_HOME:-$HOME/.config}/ago/launcher.toml"

[ -x "$REAL_BIN" ] || { echo "ago: real binary not found at $REAL_BIN" >&2; exit 1; }

# Already inside the jail container? Never recurse — run the binary directly.
if [ "${AGO_IN_JAIL:-}" = "1" ]; then exec "$REAL_BIN" "$@"; fi

read_jail_from_yaml() {
  local dir="$PWD"
  while :; do
    for f in "$dir/.ago.yaml" "$dir/.ago.yml"; do
      if [ -f "$f" ]; then
        grep -E '^[[:space:]]*jail[[:space:]]*:' "$f" | head -1 \
          | sed -E 's/.*:[[:space:]]*//; s/#.*//; s/[[:space:]]//g'
        return
      fi
    done
    [ "$dir" = "/" ] && return
    dir="$(dirname "$dir")"
  done
}

read_jail_from_launcher() {
  [ -f "$LAUNCHER_CFG" ] || return
  grep -E '^[[:space:]]*jail[[:space:]]*=' "$LAUNCHER_CFG" | head -1 \
    | sed -E 's/.*=[[:space:]]*//; s/#.*//; s/["[:space:]]//g'
}

# Read `jail_image:` from the nearest .ago.yaml walking up from cwd. The jail
# default image is bare ubuntu, so a project that needs git/rg/python/etc. can
# point this at a richer image to avoid `shell_spawn_failed`. Image values
# contain colons (`registry:tag`, `host:port`), so we strip only the KEY prefix
# up to the FIRST colon — never a greedy `.*:` that would eat the tag.
read_jail_image_from_yaml() {
  local dir="$PWD" f line
  while :; do
    for f in "$dir/.ago.yaml" "$dir/.ago.yml"; do
      if [ -f "$f" ]; then
        line="$(grep -E '^[[:space:]]*jail_image[[:space:]]*:' "$f" | head -1 || true)"
        line="${line#*:}"     # drop `  jail_image:` (first colon only)
        line="${line%%#*}"    # drop trailing comment
        # Trim surrounding whitespace and one layer of quotes.
        printf '%s' "$line" \
          | sed -E 's/^[[:space:]]*//; s/[[:space:]]*$//; s/^["'"'"']//; s/["'"'"']$//'
        return 0
      fi
    done
    [ "$dir" = "/" ] && return 0
    dir="$(dirname "$dir")"
  done
}

jail="${AGO_JAIL:-}"
[ -z "$jail" ] && jail="$(read_jail_from_yaml)"
[ -z "$jail" ] && jail="$(read_jail_from_launcher)"
jail="${jail:-true}"

# Does this invocation execute tools locally?
wants_client_tools=false
for a in "$@"; do
  [ "$a" = "--client-tools" ] && { wants_client_tools=true; break; }
done

if [ "$jail" != "true" ] || ! $wants_client_tools; then
  exec "$REAL_BIN" "$@"
fi

# ── Jailed run: same binary, inside a container mounting ONLY the project dir ──
PROJECT="$(pwd)"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/ago"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/ago"
# Image precedence: AGO_JAIL_IMAGE env > .ago.yaml `jail_image:` > default.
IMAGE="${AGO_JAIL_IMAGE:-}"
[ -z "$IMAGE" ] && IMAGE="$(read_jail_image_from_yaml)"
IMAGE="${IMAGE:-ubuntu:24.04}"

mkdir -p "$CACHE_DIR"

# Allocate a TTY only when stdin is one (interactive chat); stay pipe-friendly otherwise.
TTY_FLAGS=(-i)
[ -t 0 ] && [ -t 1 ] && TTY_FLAGS=(-i -t)

# Bridge the host keychain into the sandbox. The container has no OS Secret
# Service, so KeyringStorage there fails with PermissionDenied. Read the token
# HERE (where the keychain works) via the real binary and forward it through
# AGO_TOKEN, which the binary's EnvOverrideStorage prefers. The secret never
# touches disk — it only lives in this process's env. Empty when not logged in,
# in which case the container reports NotAuthenticated as usual. Passing `-e
# AGO_TOKEN` (no value) below inherits it without exposing it in `docker run`'s
# argv / `ps`.
if [ -z "${AGO_TOKEN:-}" ]; then
  AGO_TOKEN="$("$REAL_BIN" print-token 2>/dev/null || true)"
fi
export AGO_TOKEN

# `--log-file` may point outside the project (e.g. ~/ago-session.log). The jail
# only mounts /work, so such a path does not exist in the container and the
# binary warns "No such file or directory". Bind-mount the specific log FILE
# (never its directory — that would re-expose the host tree the jail exists to
# hide) at the same absolute path the already-tilde-expanded arg refers to.
LOG_MOUNT=()
log_path=""
prev=""
for a in "$@"; do
  case "$a" in
    --log-file=*) log_path="${a#--log-file=}" ;;
    *) [ "$prev" = "--log-file" ] && log_path="$a" ;;
  esac
  prev="$a"
done
if [ -n "$log_path" ]; then
  case "$log_path" in
    /*) abs_log="$log_path" ;;
    *)  abs_log="$PROJECT/$log_path" ;;
  esac
  # Paths under the project are already covered by the /work mount; only
  # out-of-project logs need their own file mount.
  case "$abs_log" in
    "$PROJECT"/*) : ;;
    *)
      mkdir -p "$(dirname "$abs_log")"
      [ -e "$abs_log" ] || : > "$abs_log"
      LOG_MOUNT=(-v "$abs_log":"$abs_log":rw)
      ;;
  esac
fi

# No --network host: the default bridge already gives outbound internet to reach
# the remote server, while keeping the container off the host's loopback. If your
# .ago.yaml points at https://localhost:5005, add `--network host` and AGO_INSECURE=1.
# AGO_IN_JAIL=1 tells the binary the session IS sandboxed (skips its warning) and
# stops this wrapper from recursing if it is the one on PATH inside the container.
exec docker run --rm "${TTY_FLAGS[@]}" \
  --user "$(id -u):$(id -g)" \
  -e HOME=/home/u \
  -e AGO_IN_JAIL=1 \
  -e AGO_TOKEN \
  -e AGO_INSECURE="${AGO_INSECURE:-}" \
  -v "$PROJECT":/work:rw \
  -v "$REAL_BIN":/usr/local/bin/ago:ro \
  -v "$CONFIG_DIR":/home/u/.config/ago:rw \
  -v "$CACHE_DIR":/home/u/.cache/ago:rw \
  ${LOG_MOUNT[@]+"${LOG_MOUNT[@]}"} \
  -w /work \
  "$IMAGE" \
  ago "$@"

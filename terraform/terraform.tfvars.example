# ============================================================
# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars (it's in .gitignore)
# ============================================================

aws_region    = "eu-west-1"
instance_type = "t3.medium"

# Your public IP for SSH access (find it: curl ifconfig.me)
ssh_allowed_cidrs = ["YOUR_IP/32"]

# SSH public key (generate: ssh-keygen -t ed25519 -f ~/.ssh/agent-orchestrator -N "")
ssh_public_key = "ssh-ed25519 AAAA... your-email@example.com"

# Agent Orchestrator — environment variable template
#
# Copy to `.env.local` (gitignored) and fill in real values for local
# development. For production, set these as real environment variables on
# the host or via a secrets manager (see docs/security.md).
#
# Never commit `.env.local`, `.env`, or any file containing real secrets.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

# Public URL of the deployed dashboard (used for OAuth2 redirect URIs).
# Locally: https://localhost:5005
BASE_URL=https://localhost:5005

# Strong random string (>= 32 bytes). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Also reused as the Starlette session signing key (for OAuth state).
JWT_SECRET_KEY=

# Comma-separated API keys for programmatic (non-browser) access via
# the X-API-Key header. Empty = no API key auth.
DASHBOARD_API_KEYS=

# Set to "production" on the production host; leave unset locally.
# ENVIRONMENT=production

# ---------------------------------------------------------------------------
# OAuth — GitHub (existing)
# ---------------------------------------------------------------------------
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: ${BASE_URL}/auth/github/callback

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# GitHub username of the admin (auto-created with admin role on first login).
GITHUB_USERNAME=

# ---------------------------------------------------------------------------
# OAuth — Google (new)
# ---------------------------------------------------------------------------
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: ${BASE_URL}/auth/google/callback

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Comma-separated allowlist of Google email addresses authorized to log in.
# Case-insensitive. Supports domain wildcards via `*@domain.tld`.
# Empty = nobody can log in via Google (fail-closed).
# Examples:
#   ALLOWED_GOOGLE_EMAILS=alice@gmail.com
#   ALLOWED_GOOGLE_EMAILS=alice@gmail.com, bob@example.com, *@mycompany.com
ALLOWED_GOOGLE_EMAILS=

# ---------------------------------------------------------------------------
# LLM providers (set the ones you use)
# ---------------------------------------------------------------------------

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------

# Used by docker-compose.prod.yml / split.yml; ignore for the dev compose
# which uses a fixed dev password.
POSTGRES_PASSWORD=

# Direct DSN override (e.g. when not using docker-compose).
# DATABASE_URL=postgresql://orchestrator:orchestrator@localhost:5432/orchestrator

# ---------------------------------------------------------------------------
# Sandbox (optional)
# ---------------------------------------------------------------------------

# SANDBOX_ENABLED=false
# SANDBOX_TYPE=docker
# SANDBOX_IMAGE=python:3.12-slim
# SANDBOX_MAX_CONCURRENT=10

# ---------------------------------------------------------------------------
# Dev mode escape hatch — NEVER set in production
# ---------------------------------------------------------------------------

# ALLOW_DEV_MODE=true

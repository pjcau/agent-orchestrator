# Agent Orchestrator — YAML Configuration Example
#
# Copy to orchestrator.yaml and customise.
# Environment variables can be referenced with ${VAR_NAME} syntax.

config_version: 1

# ---------------------------------------------------------------------------
# Providers — LLM backends available to agents
# ---------------------------------------------------------------------------
providers:
  local:
    use: agent_orchestrator.providers.local:LocalProvider
    params:
      base_url: "http://localhost:11434"

  openrouter:
    use: agent_orchestrator.providers.openrouter:OpenRouterProvider
    params:
      api_key: "${OPENROUTER_API_KEY}"

  anthropic:
    use: agent_orchestrator.providers.anthropic:AnthropicProvider
    params:
      api_key: "${ANTHROPIC_API_KEY}"

# ---------------------------------------------------------------------------
# Agents — autonomous units with roles and tools
# ---------------------------------------------------------------------------
agents:
  backend:
    provider: local
    model: qwen2.5-coder
    max_steps: 10
    skills: [file_read, file_write, shell_exec]

  frontend:
    provider: local
    model: qwen2.5-coder
    max_steps: 8
    skills: [file_read, file_write]

  ai-engineer:
    provider: anthropic
    model: claude-sonnet-4-20250514
    max_steps: 15
    skills: [file_read, file_write, shell_exec, web_reader]

# ---------------------------------------------------------------------------
# Routing — how tasks are assigned to providers
# ---------------------------------------------------------------------------
routing:
  strategy: complexity_based
  fallback_chain: [local, openrouter]

# ---------------------------------------------------------------------------
# Budgets — cost guardrails
# ---------------------------------------------------------------------------
budgets:
  daily_limit_usd: 5.00
  per_task_limit_usd: 0.50
  alert_threshold_pct: 80

# ---------------------------------------------------------------------------
# Guardrails — opt-in pre/post LLM-call safety layer (P3)
# ---------------------------------------------------------------------------
# Each guardrail runs before (input) or after (output) every LLM call.
# On "block", Agent.execute() raises GuardrailBlocked (RuntimeError).
# On "redact", the matched text is masked before the call proceeds.
#
guardrails:
  input:
    - type: pii_scanner        # Redacts email, phone, SSN, IBAN, credit card
      action: redact
    - type: secrets_scanner    # Blocks AWS keys, GitHub tokens, generic API keys
      action: block
    - type: prompt_injection   # Blocks "ignore previous instructions" and similar
      action: block
  output:
    - type: output_schema      # Validates assistant output against a JSON Schema
      schema_path: ./schemas/response.json
      action: block
    # - type: output_schema
    #   schema:                # Inline schema (alternative to schema_path)
    #     type: object
    #     required: [answer]
    #     properties:
    #       answer: {type: string}

# ---------------------------------------------------------------------------
# Sandbox — isolated execution environment for agent code
# ---------------------------------------------------------------------------
sandbox:
  enabled: false              # Set true to enable per-session sandboxes
  type: docker                # "docker" (production) or "local" (testing)
  image: "python:3.12-slim"   # Default Docker image for sandboxes
  timeout_seconds: 60         # Default command timeout
  memory_limit: "512m"        # Docker memory limit per container
  max_concurrent: 10          # Max simultaneous sandbox containers
  port_range_start: 9000      # Host port allocation range (start)
  port_range_end: 9099        # Host port allocation range (end)

# ---------------------------------------------------------------------------
# Repair loop (v1.5 P1) — verify-and-retry around run_team()
# Opt-in. When enabled, every /api/team/run goes through
# `_run_team_with_repair`: SyntaxVerifier → EncodingVerifier →
# DependencyVerifier, with FailurePatternRegistry auto-fixes applied before
# any LLM retry. See docs/architecture-repair-loop.md.
#
# These keys mirror env vars consumed by `dashboard/agent_runtime_router.py`
# (env vars take precedence so the dashboard can be toggled without editing
# this file):
#   REPAIR_LOOP_ENABLED        — "true" to enable (default off)
#   REPAIR_LOOP_MAX_ATTEMPTS   — hard retry cap (default 5)
#   REPAIR_LOOP_MAX_COST_USD   — cumulative cost cap (default 0.50)
# ---------------------------------------------------------------------------
repair_loop:
  enabled: false              # Flip to true for a sprint, watch metrics, then promote
  max_attempts: 5             # Includes the first attempt; 5 = one initial + four retries
  max_cost_usd: 0.50          # Aborts as soon as cumulative cost exceeds this
  patterns: core/failure_patterns.yaml   # Bundled deterministic auto-fixes
  verifiers:
    - syntax                  # py_compile + json.loads
    - encoding                # catches literal-\n corruption (frontend/package.json case)
    - dependency              # static check against KNOWN_BAD_PINS (e.g. psycopg<3)
